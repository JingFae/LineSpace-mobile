# Mock mode is explicit and uses the fixed development identity below.
# Production Web must set USE_MOCKS=false and a deployed HTTPS API base URL.
EXPO_PUBLIC_API_BASE_URL=http://localhost:4000
EXPO_PUBLIC_USE_MOCKS=true
EXPO_PUBLIC_CURRENT_USER_ID=user-lili
PORT=4000
OPENAI_API_KEY=
# Optional overrides. Community Spark otherwise uses the general model value.
OPENAI_MODEL=
OPENAI_COMMUNITY_SPARK_MODEL=
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/linespace
SUPABASE_URL=
# Preferred public server-side key. SUPABASE_ANON_KEY remains a legacy fallback.
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Web: https://<web-domain>/auth/confirm; Native: linespace://auth/confirm
AUTH_EMAIL_REDIRECT_URL=http://localhost:8081/auth/confirm
