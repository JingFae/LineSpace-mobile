{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"],
      "env": [
        "EXPO_PUBLIC_API_BASE_URL",
        "EXPO_PUBLIC_CURRENT_USER_ID",
        "EXPO_PUBLIC_USE_MOCKS"
      ]
    },
    "typecheck": {
      "dependsOn": ["^typecheck"],
      "outputs": []
    },
    "lint": {
      "dependsOn": ["^lint"],
      "outputs": []
    }
  }
}
