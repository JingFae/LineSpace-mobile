{
  "name": "linespace",
  "private": true,
  "type": "module",
  "version": "0.1.0",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "pnpm --filter @linespace/mobile dev",
    "dev:web": "pnpm --filter @linespace/mobile web",
    "dev:api": "pnpm --filter @linespace/api dev",
    "dev:api:local": "node scripts/dev-api-local.mjs",
    "typecheck": "pnpm -r --workspace-concurrency=1 --if-present typecheck",
    "build": "turbo run build",
    "build:web": "pnpm --filter @linespace/mobile export:web",
    "check:api": "pnpm --filter @linespace/api check",
    "check": "pnpm typecheck && pnpm check:api && pnpm build:web",
    "lint": "pnpm typecheck",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset --local",
    "db:lint": "supabase db lint --local --level warning",
    "db:security-check": "pnpm --filter @linespace/api check:db:local",
    "db:push:dry-run": "supabase db push --linked --dry-run",
    "db:push": "supabase db push --linked"
  },
  "devDependencies": {
    "supabase": "^2.109.1",
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
