{
  "name": "linespace",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@11.7.0",
  "scripts": {
    "dev": "pnpm --filter @linespace/mobile dev",
    "dev:web": "pnpm --filter @linespace/mobile web",
    "dev:api": "pnpm --filter @linespace/api dev",
    "typecheck": "pnpm -r --if-present typecheck",
    "build": "turbo build",
    "lint": "pnpm -r --if-present lint"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2"
  }
}
