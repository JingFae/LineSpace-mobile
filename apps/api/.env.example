# Server-only variables. Never prefix these with EXPO_PUBLIC_.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
AUTH_EMAIL_REDIRECT_URL=http://localhost:8081/auth/confirm

# Enables Community Spark / Creative Spark.
DEEPSEEK_API_KEY=sk-your-deepseek-key
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_COMMUNITY_SPARK_MODEL=deepseek-v4-flash

# Optional: enables the legacy /v1/ai/assist recommendation boundary.
OPENAI_API_KEY=sk-your-key
OPENAI_MODEL=gpt-4.1-mini
