{
  "name": "@linespace/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/server.ts",
    "check": "tsx src/auth-check.ts && tsx src/smoke-check.ts && tsx src/community-spark-check.ts && tsx src/database/checks/migration-check.ts && tsx src/vercel-check.ts",
    "check:db:local": "tsx src/database/checks/local-security-check.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@linespace/api-client": "workspace:*",
    "@supabase/supabase-js": "^2.110.5",
    "tsx": "^4.19.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  }
}
