{
  "expo": {
    "name": "LineSpace",
    "slug": "linespace",
    "scheme": "linespace",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {},
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow LineSpace to choose a profile photo from your library."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
